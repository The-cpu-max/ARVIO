name: Build APKs

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurim'
      
      - name: Make gradlew executable
        run: chmod +x ./gradlew
      
      - name: Build Debug APK
        run: ./gradlew assembleSideloadDebug
      
      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: ARVIO-Debug
          path: app/build/outputs/apk/sideload/debug/
